{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "analytics-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-26",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "PLAUSIBLE_ORIGIN_HOSTNAME": "analytics.lobst3rs.com"
  }
}
