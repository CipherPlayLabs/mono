---
services:
  plausible:
    image: "{{ plausible_app_image }}"
    restart: unless-stopped
    command: sh -c "/entrypoint.sh db createdb && /entrypoint.sh db migrate && /entrypoint.sh run"
    depends_on:
      postgres:
        condition: service_healthy
      clickhouse:
        condition: service_healthy
    env_file:
      - ./plausible.env
    ports:
      - "{{ plausible_local_bind_address }}:{{ plausible_local_port }}:8000"
    volumes:
      - plausible_data:/var/lib/plausible
    ulimits:
      nofile:
        soft: 65535
        hard: 65535
    environment:
      ERL_FLAGS: "+sbwt none +sbwtdcpu none +sbwtdio none"

  postgres:
    image: "{{ plausible_postgres_image }}"
    restart: unless-stopped
    environment:
      POSTGRES_DB: "{{ plausible_postgres_db }}"
      POSTGRES_USER: "{{ plausible_postgres_user }}"
      POSTGRES_PASSWORD: "{{ plausible_postgres_password }}"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ plausible_postgres_user }} -d {{ plausible_postgres_db }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    volumes:
      - postgres_data:/var/lib/postgresql/data

  clickhouse:
    image: "{{ plausible_clickhouse_image }}"
    restart: unless-stopped
    ulimits:
      nofile:
        soft: 262144
        hard: 262144
    healthcheck:
      test: ["CMD-SHELL", "wget --no-verbose --tries=1 -O - http://127.0.0.1:8123/ping || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 1m
    volumes:
      - clickhouse_data:/var/lib/clickhouse
      - clickhouse_logs:/var/log/clickhouse-server
      - clickhouse_backups:/backups
      - ./clickhouse/logs.xml:/etc/clickhouse-server/config.d/logs.xml:ro
      - ./clickhouse/ipv4-only.xml:/etc/clickhouse-server/config.d/ipv4-only.xml:ro
      - ./clickhouse/low-resources.xml:/etc/clickhouse-server/config.d/low-resources.xml:ro

volumes:
  plausible_data:
    driver: local
  postgres_data:
    driver: local
  clickhouse_data:
    driver: local
  clickhouse_logs:
    driver: local
  clickhouse_backups:
    driver: local
